# Telegram bot — get from @BotFather
BOT_TOKEN=

# Public URL of the deployed mini app (the web_app button target)
WEBAPP_URL=https://printscout-webapp.vercel.app

# Public URL of this backend (used to register the Telegram webhook)
PUBLIC_BASE_URL=https://printscout-api.fly.dev

# Webhook secret token sent by Telegram in X-Telegram-Bot-Api-Secret-Token header
WEBHOOK_SECRET=change-me

# Database
DATABASE_URL=postgresql+asyncpg://printscout:printscout@localhost:5432/printscout

# Optional source API keys
THINGIVERSE_TOKEN=
MYMINIFACTORY_KEY=

# DEV ONLY — when > 0, skips Telegram initData validation and treats every
# request as coming from this Telegram user id. MUST be 0 (or unset) in prod.
DEV_FAKE_USER_ID=0
